# ── Endee Vector Database ────────────────────────────────────────────────────
# URL of the running Endee server (change host/port if using remote Docker)
ENDEE_HOST=http://localhost:8080

# Leave blank if the server runs without auth (default docker-compose.yml)
# Set to your NDD_AUTH_TOKEN value if auth is enabled on the server
ENDEE_AUTH_TOKEN=

# Index / collection settings (safe to leave as defaults)
ENDEE_INDEX_NAME=news_embeddings
ENDEE_DIM=384
ENDEE_SPACE_TYPE=cosine
ENDEE_PRECISION=int16
ENDEE_M=16
ENDEE_EF_CON=200
ENDEE_TIMEOUT_SEC=30

# ── NewsAPI ──────────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here
NEWS_PAGE_SIZE=100
NEWS_TOPICS=AI,technology,science,finance,climate

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=64

# ── LLM Intelligence Layer ───────────────────────────────────────────────────
# Get a FREE Groq key at https://console.groq.com  (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
LLM_BACKEND=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_DIVERSITY_THRESHOLD=0.4
